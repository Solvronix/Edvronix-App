 "html": "<style>\r\n/* A4 page wrapper */\r\n.print-wrapper {\r\n    width: 210mm;\r\n    min-height: 297mm;\r\n    margin: 0 auto;\r\n    padding: 10px;\r\n    font-family: 'Segoe UI', Arial, sans-serif;\r\n    font-size: 10.5px;\r\n    color: #222;\r\n    background-color: #fff;\r\n}\r\n\r\n/* Header adjustments */\r\n.print-wrapper table tr td img {\r\n    max-height: 50px; /* smaller logo */\r\n}\r\n\r\n/* Reduce table paddings */\r\n.print-wrapper table td,\r\n.print-wrapper table th {\r\n    padding: 6px !important;\r\n    font-size: 10.5px;\r\n    vertical-align: top;\r\n}\r\n\r\n/* Section header font */\r\n.print-wrapper .section-header {\r\n    font-size: 12px;\r\n    padding: 4px 8px !important;\r\n}\r\n\r\n/* Photo box */\r\n.print-wrapper .photo-box {\r\n    height: 130px;\r\n    border: 2px dashed #1a3a5f;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    text-align: center;\r\n    font-size: 11px;\r\n    font-weight: 700;\r\n    color: #1a3a5f;\r\n    background: #f9fbfd;\r\n}\r\n\r\n/* Photo image scaling */\r\n.print-wrapper .photo-box img {\r\n    max-height: 100%;\r\n    max-width: 100%;\r\n    object-fit: contain;\r\n}\r\n\r\n/* Avoid page break inside sections */\r\n.print-wrapper .section {\r\n    page-break-inside: avoid;\r\n}\r\n\r\n/* For print only */\r\n@media print {\r\n    body {\r\n        margin: 0;\r\n    }\r\n    .print-wrapper {\r\n        width: 100%;\r\n        min-height: 100%;\r\n        box-shadow: none;\r\n    }\r\n}\r\n</style>\r\n\r\n<div class=\"print-wrapper\">\r\n\r\n    <!-- HEADER -->\r\n<!-- HEADER -->\r\n<table style=\"width: 100%; border-bottom: 3px solid #1a3a5f; border-collapse: collapse;\">\r\n    <tr>\r\n        <!-- LOGO -->\r\n        <td style=\"width: 100px; vertical-align: middle; text-align: center; padding: 0;\">\r\n            <img src=\"/files/apple-icon-precomposed.png\" \r\n                 style=\"height: 55px; width: auto; display: block; margin: auto;\">\r\n        </td>\r\n\r\n        <!-- SCHOOL NAME & INFO -->\r\n        <td style=\"vertical-align: middle; padding-left: 10px;\">\r\n            <div style=\"font-size: 18px; font-weight: 800; color: #1a3a5f; letter-spacing: -0.3px; margin-bottom: 2px;\">\r\n                AL-FAISAL SCHOOL SYSTEM\r\n            </div>\r\n            <div style=\"font-size: 11px; color: #444; line-height: 1.4;\">\r\n                Ghuman Town near Sabzi Mandi, Lahore Road, Sheikhupura<br>\r\n                <b>Ph:</b> 056-3792111 &nbsp;|&nbsp; <b>Mob:</b> +92-300-4468803<br>\r\n                <b>Email:</b> accounts@alfss.edu.pk &nbsp;|&nbsp; <b>Web:</b> www.alfss.edu.pk\r\n            </div>\r\n        </td>\r\n\r\n        <!-- ADMISSION FORM -->\r\n        <td style=\"vertical-align: middle; text-align: right; padding-left: 10px;\">\r\n            <div style=\"font-size: 16px; font-weight: 800; color: #b02a2a; letter-spacing: 1px;\">\r\n                ADMISSION FORM\r\n            </div>\r\n            <div style=\"font-size: 11px; font-weight: 600; margin-top: 4px; color: #333;\">\r\n                <b>ACADEMIC SESSION:</b> {{ doc.academic_year }}\r\n            </div>\r\n        </td>\r\n    </tr>\r\n</table>\r\n\r\n    <!-- META -->\r\n    <div style=\"\r\n        background: #f3f5f8;\r\n        border: 1px solid #cfd6df;\r\n        padding: 7px 12px;\r\n        margin-top: 12px;\r\n        font-size: 11.5px;\r\n        font-weight: 600;\r\n        display: flex;\r\n        justify-content: space-between;\r\n    \">\r\n        <span>FORM TRACKING ID: {{doc.name}}</span>\r\n        <span>ISSUE DATE: {{doc.application_date}}</span>\r\n    </div>\r\n\r\n    <!-- SECTION 1 -->\r\n    <div style=\"margin-top: 10px;\">\r\n        <div style=\"\r\n            background: #1a3a5f;\r\n            color: #fff;\r\n            padding: 6px 12px;\r\n            font-size: 13px;\r\n            font-weight: 700;\r\n            letter-spacing: 0.5px;\r\n        \">\r\n            01. STUDENT PARTICULARS\r\n        </div>\r\n\r\n        <table style=\"width: 100%; border-collapse: collapse; font-size: 11px;\">\r\n            <tr>\r\n                <td style=\"width: 20%; border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Student Name</td>\r\n                <td style=\"width: 30%; border: 1px solid #cfcfcf; padding: 6px;\">{{doc.title}}</td>\r\n                <td style=\"width: 20%; border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Date of Birth</td>\r\n                <td style=\"width: 30%; border: 1px solid #cfcfcf; padding: 6px;\">{{doc.date_of_birth}}</td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Class Applied For</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{doc.program}}</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Section</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{doc.student_category}}</td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Gender</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{doc.gender}}</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Email Address</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{doc.student_email_id}}</td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Remarks</td>\r\n                <td colspan=\"3\" style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{doc.small_text_nwlk}}</td>\r\n            </tr>\r\n        </table>\r\n    </div>\r\n\r\n    <!-- SECTION 2 -->\r\n    <div style=\"margin-top: 10px;\">\r\n        <div style=\"\r\n            background: #1a3a5f;\r\n            color: #fff;\r\n            padding: 6px 12px;\r\n            font-size: 13px;\r\n            font-weight: 700;\r\n            letter-spacing: 0.5px;\r\n        \">\r\n            02. GUARDIAN / PARENT DETAILS\r\n        </div>\r\n\r\n        <table style=\"width: 100%; border-collapse: collapse; font-size: 12px;\">\r\n            {% for row in doc.guardians %}\r\n            {% set guardian = frappe.get_doc(\"Guardian\", row.guardian) %}\r\n            <tr>\r\n                <td style=\"width: 20%; border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Parent Name</td>\r\n                <td style=\"width: 30%; border: 1px solid #cfcfcf; padding: 6px;\">{{guardian.guardian_name}}</td>\r\n                <td style=\"width: 20%; border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Parent CNIC</td>\r\n                <td style=\"width: 30%; border: 1px solid #cfcfcf; padding: 6px;\">{{guardian.custom_cnic_no}}</td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Guardian Occupation</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{guardian.occupation}}</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Mobile Number</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{guardian.mobile_number}}</td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Email Address</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{guardian.email_address}}</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Relationship to Student</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px;\">{{row.relation}}</td>\r\n            </tr>\r\n            {% endfor %}\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 6px; background: #f8f9fb;\">Postal Address</td>\r\n                <td colspan=\"3\" style=\"border: 1px solid #cfcfcf; padding: 8px;\">{{doc.address_line_1}}</td>\r\n            </tr>\r\n        </table>\r\n    </div>\r\n\r\n    <!-- SECTION 3 + PHOTO -->\r\n    <table style=\"width: 100%; margin-top: 10px; border-collapse: collapse;\">\r\n        <tr>\r\n            <td style=\"width: 70%; vertical-align: top; padding-right: 15px;\">\r\n                <div style=\"\r\n                    background: #b02a2a;\r\n                    color: #fff;\r\n                    padding: 6px 12px;\r\n                    font-size: 12px;\r\n                    font-weight: 700;\r\n                    letter-spacing: 0.5px;\r\n                \">\r\n                    03. DOCUMENT CHECKLIST\r\n                </div>\r\n                <div style=\"border: 1px solid #cfcfcf; padding: 8px; font-size: 11.5px; line-height: 1.7;\">\r\n                    \u2610 2 Passport Size Photographs (Blue Background)<br>\r\n                    \u2610 Attested Copy of Student's B-Form / CNIC<br>\r\n                    \u2610 Attested Copy of Father's / Guardian's CNIC<br>\r\n                    \u2610 Original School Leaving Certificate (SLC)<br>\r\n                    \u2610 Copy of Previous Class Result Card\r\n                </div>\r\n            </td>\r\n            <td style=\"width: 30%; vertical-align: top;\">\r\n                <div class=\"photo-box\">\r\n                    {%if doc.image%}\r\n                        <img src=\"{{ doc.image }}\">\r\n                    {%else%}\r\n                        <PASTE RECENT<br>PHOTOGRAPH<br>HERE\r\n                    {%endif%}\r\n                </div>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n    <!-- SECTION 4 -->\r\n    <div style=\"margin-top: 12px;\">\r\n        <div style=\"\r\n            background: #4a4a4a;\r\n            color: #fff;\r\n            padding: 6px 12px;\r\n            font-size: 12px;\r\n            font-weight: 700;\r\n            letter-spacing: 0.5px;\r\n        \">\r\n            04. FOR OFFICE USE ONLY\r\n        </div>\r\n        <table style=\"width: 100%; border-collapse: collapse; font-size: 11.5px;\">\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%; background:#f8f9fb;\">Registration Status</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%;\">{{doc.application_status}}</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%; background:#f8f9fb;\">Admission Fee</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%;\"></td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%; background:#f8f9fb;\">Monthly Tuition Fee</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%;\"></td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%; background:#f8f9fb;\">Annual Funds</td>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; width: 25%;\"></td>\r\n            </tr>\r\n            <tr>\r\n                <td style=\"border: 1px solid #cfcfcf; padding: 7px; background:#f8f9fb;\">Amount</td>\r\n                <td colspan=\"3\" style=\"border: 1px solid #cfcfcf; padding: 7px; font-weight: 800; background:#f1f3f6;\">\r\n                    Rs ______________________\r\n                </td>\r\n            </tr>\r\n        </table>\r\n    </div>\r\n\r\n    <!-- DECLARATION -->\r\n    <div style=\"margin-top: 12px; border: 1px solid #cfcfcf; padding: 8px; background:#fafbfd;\">\r\n        <div style=\"\r\n            font-size: 11.5px;\r\n            font-weight: 800;\r\n            color: #b02a2a;\r\n            text-decoration: underline;\r\n            margin-bottom: 6px;\r\n        \">\r\n            DECLARATION & POLICY\r\n        </div>\r\n        <div style=\"font-size: 10.8px; line-height: 1.6; text-align: justify;\">\r\n            \ud83d\udc49 I solemnly declare that the date of birth and all particulars stated in this form are true and correct to the best of my knowledge.<br>\r\n            \ud83d\udc49 I undertake to abide by all rules, academic policies, and disciplinary regulations of Al-Faisal School System.<br>\r\n            \ud83d\udc49 The school reserves the right to cancel admission in case of any misinformation or misconduct.<br>\r\n            <b>\ud83d\udc49 Fee is not Refundable in any case.</b>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- SIGNATURES -->\r\n    <table style=\"width: 100%; margin-top: 55px; text-align: center; font-size: 12px;\">\r\n        <tr>\r\n            <td style=\"width: 33%;\">\r\n                <div style=\"border-top: 1px solid #000; margin: 0 20px; padding-top: 6px; font-weight: 700;\">\r\n                    Parent / Guardian Signature\r\n                </div>\r\n            </td>\r\n            <td style=\"width: 33%;\">\r\n                <div style=\"border-top: 1px solid #000; margin: 0 20px; padding-top: 6px; font-weight: 700;\">\r\n                    Authorized Admission Officer\r\n                </div>\r\n            </td>\r\n            <td style=\"width: 33%;\">\r\n                <div style=\"border-top: 1px solid #000; margin: 0 20px; padding-top: 6px; font-weight: 700;\">\r\n                    Principal Signature & Stamp\r\n                </div>\r\n            </td>\r\n        </tr>\r\n    </table>\r\n\r\n</div>",
