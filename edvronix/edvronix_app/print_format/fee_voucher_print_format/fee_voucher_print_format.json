 "html": "<style>\r\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');\r\n\r\n    .print-format { padding: 0 !important; background: #fff !important; }\r\n\r\n    .voucher-container {\r\n        font-family: 'Inter', sans-serif;\r\n        color: #1a202c;\r\n        width: 100%;\r\n        max-width: 900px;\r\n        margin: 0 auto;\r\n    }\r\n\r\n    .voucher-body {\r\n        padding: 20px 30px;\r\n        display: flex;\r\n        flex-direction: column;\r\n        page-break-inside: avoid;\r\n    }\r\n\r\n    .divider {\r\n        border-top: 2px dashed #cbd5e0;\r\n        margin: 30px 0;\r\n        position: relative;\r\n        height: 20px;\r\n    }\r\n\r\n    .divider:after {\r\n        content: \"\u2702 SCISSORS CUT HERE\";\r\n        position: absolute;\r\n        top: 0%;\r\n        left: 50%;\r\n        transform: translate(-50%, -50%);\r\n        background: #fff;\r\n        padding: 0 10px;\r\n        font-size: 10px;\r\n        font-weight: 700;\r\n        color: #a0aec0;\r\n        letter-spacing: 2px;\r\n        white-space: nowrap;\r\n    }\r\n\r\n    .copy-label {\r\n        background: #1a365d;\r\n        color: #fff;\r\n        padding: 4px 10px;\r\n        font-size: 10px;\r\n        font-weight: 700;\r\n        border-radius: 4px;\r\n        text-transform: uppercase;\r\n    }\r\n\r\n    .header-flex {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        align-items: center;\r\n        border-bottom: 3px solid #1a365d;\r\n        padding-bottom: 10px;\r\n        margin-bottom: 15px;\r\n    }\r\n\r\n    .header-left-group {\r\n        display: flex;\r\n        align-items: center;\r\n        gap: 15px;\r\n    }\r\n\r\n    .school-logo-img {\r\n        max-height: 60px;\r\n    }\r\n\r\n    .school-name {\r\n        font-size: 20px;\r\n        font-weight: 800;\r\n        color: #1a365d;\r\n        margin: 0;\r\n        text-transform: uppercase;\r\n    }\r\n\r\n    .main-title-container {\r\n        text-align: right;\r\n    }\r\n\r\n    .main-title {\r\n        font-size: 24px;\r\n        font-weight: 900;\r\n        color: #1a365d;\r\n        margin: 0;\r\n    }\r\n\r\n    .fee-month-subtitle {\r\n        font-size: 14px;\r\n        font-weight: 700;\r\n        color: #4a5568;\r\n        text-transform: uppercase;\r\n    }\r\n\r\n    .info-grid {\r\n        display: grid;\r\n        grid-template-columns: 1fr 1fr 1.5fr;\r\n        gap: 15px;\r\n        margin-bottom: 15px;\r\n    }\r\n\r\n    .info-item label {\r\n        font-size: 9px;\r\n        font-weight: 700;\r\n        color: #718096;\r\n        text-transform: uppercase;\r\n        display: block;\r\n        margin-bottom: 3px;\r\n    }\r\n\r\n    .info-item span {\r\n        font-size: 12px;\r\n        font-weight: 600;\r\n        color: #2d3748;\r\n    }\r\n\r\n    /* Style for Status within the data section */\r\n    .status-text {\r\n        font-weight: 800;\r\n        text-transform: uppercase;\r\n    }\r\n    .text-paid { color: #2f855a; }\r\n    .text-unpaid { color: #c53030; }\r\n\r\n    .payable-callout {\r\n        background: #f1f5f9;\r\n        padding: 10px;\r\n        border-radius: 6px;\r\n        border-left: 5px solid #1a365d;\r\n    }\r\n\r\n    .payable-amount {\r\n        font-size: 20px;\r\n        font-weight: 800;\r\n        color: #1a365d;\r\n        text-align: right;\r\n        border-bottom: 1px solid #cbd5e0;\r\n        padding-bottom: 3px;\r\n        margin-bottom: 5px;\r\n    }\r\n\r\n    .due-date-row {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        font-size: 11px;\r\n        font-weight: 700;\r\n    }\r\n\r\n    .fee-table {\r\n        width: 100%;\r\n        border-collapse: collapse;\r\n        margin-bottom: 15px;\r\n    }\r\n\r\n    .fee-table th {\r\n        background: #f8fafc;\r\n        border-bottom: 1px solid #e2e8f0;\r\n        padding: 8px;\r\n        font-size: 10px;\r\n        text-transform: uppercase;\r\n        text-align: left;\r\n    }\r\n\r\n    .fee-table td {\r\n        padding: 8px 6px;\r\n        border-bottom: 1px solid #edf2f7;\r\n        font-size: 11px;\r\n    }\r\n\r\n    .summary-section {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        align-items: flex-start;\r\n    }\r\n\r\n    .terms {\r\n        font-size: 10px;\r\n        color: #4a5568;\r\n        line-height: 1.4;\r\n    }\r\n\r\n    .terms b {\r\n        display: block;\r\n        margin-bottom: 3px;\r\n        color: #1a365d;\r\n    }\r\n\r\n    .summary-box {\r\n        width: 220px;\r\n    }\r\n\r\n    .summary-row {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        font-size: 12px;\r\n        margin-bottom: 3px;\r\n    }\r\n\r\n    .total-line {\r\n        display: flex;\r\n        justify-content: space-between;\r\n        border-top: 2px solid #1a365d;\r\n        padding-top: 5px;\r\n        margin-top: 5px;\r\n        font-size: 16px;\r\n        font-weight: 800;\r\n        color: #1a365d;\r\n    }\r\n\r\n    @media print {\r\n        body { margin: 0; }\r\n        .voucher-body { padding: 15px 20px; }\r\n        .main-title { font-size: 22px; }\r\n    }\r\n</style>\r\n\r\n<div class=\"voucher-container\">\r\n\r\n{% set company_logo = \"http://185.217.126.162:8000/files/apple-icon-precomposed.png\" %}\r\n\r\n{% set enrollment = frappe.get_all(\r\n    \"Program Enrollment\",\r\n    filters={\"student\": doc.student, \"docstatus\": 1},\r\n    fields=[\"program\", \"student_category\"],\r\n    order_by=\"creation desc\",\r\n    limit=1\r\n) %}\r\n\r\n{% set program_name = enrollment[0].program if enrollment else \"N/A\" %}\r\n{% set category_name = enrollment[0].student_category if enrollment else \"N/A\" %}\r\n\r\n{# ================= FEE MONTH LOGIC ================= #}\r\n{% set fee_month = \"\" %}\r\n{% if doc.due_date %}\r\n    {% set fee_month = frappe.utils.formatdate(doc.due_date, \"MMMM yyyy\") %}\r\n{% endif %}\r\n{# =================================================== #}\r\n\r\n{% for copy in [\"Parent Copy\", \"Office Copy\"] %}\r\n<div class=\"voucher-body\">\r\n\r\n    <div style=\"display:flex; justify-content:space-between; margin-bottom:10px;\">\r\n        <div class=\"copy-label\">{{ copy }}</div>\r\n        <div style=\"font-size:10px; color:#718096; text-align:right;\">\r\n            <div>Voucher ID: <b>{{ doc.name }}</b></div>\r\n            <div>Issued: {{ doc.get_formatted(\"posting_date\") }}</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"header-flex\">\r\n        <div class=\"header-left-group\">\r\n            <img src=\"{{ company_logo }}\" class=\"school-logo-img\">\r\n            <div>\r\n                <h1 class=\"school-name\">Al-Faisal School System</h1>\r\n                <div style=\"font-size:10px; color:#718096; font-weight:600;\">\r\n                    Student Accounts Department\r\n                </div>\r\n            </div>\r\n        </div>\r\n        <div class=\"main-title-container\">\r\n            <h1 class=\"main-title\">FEE VOUCHER</h1>\r\n            <div class=\"fee-month-subtitle\">{{ fee_month }}</div>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"info-grid\">\r\n        <div class=\"info-item\">\r\n            <label>Student Name</label>\r\n            <span>{{ doc.customer_name }}</span>\r\n        </div>\r\n        <div class=\"info-item\">\r\n            <label>Student ID</label>\r\n            <span>{{ doc.student }}</span>\r\n        </div>\r\n\r\n        <div class=\"info-item\" style=\"grid-row:span 3;\">\r\n            <div class=\"payable-callout\">\r\n                <label style=\"text-align:right; font-size:9px;\">Total Amount Due</label>\r\n                {% set display_total = 0 if doc.status == \"Paid\"\r\n                    else (doc.outstanding_amount if doc.outstanding_amount > 0 else doc.grand_total) %}\r\n                <div class=\"payable-amount\">Rs {{ \"{:,.2f}\".format(display_total) }}</div>\r\n                <div class=\"due-date-row\">\r\n                    <span>DUE DATE</span>\r\n                    <span>{{ doc.get_formatted(\"due_date\") }}</span>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"info-item\">\r\n            <label>Program</label>\r\n            <span>{{ program_name }}</span>\r\n        </div>\r\n\r\n        <div class=\"info-item\">\r\n            <label>Category</label>\r\n            <span>{{ category_name }}</span>\r\n        </div>\r\n\r\n        <div class=\"info-item\">\r\n            <label>Payment Status</label>\r\n            <span class=\"status-text {{ 'text-paid' if doc.status == 'Paid' else 'text-unpaid' }}\">\r\n                {{ doc.status }}\r\n            </span>\r\n        </div>\r\n    </div>\r\n\r\n    <table class=\"fee-table\">\r\n        <thead>\r\n            <tr>\r\n                <th width=\"70%\">Fee Description</th>\r\n                <th style=\"text-align: center;\">Qty</th>\r\n                <th style=\"text-align: right;\">Amount</th>\r\n            </tr>\r\n        </thead>\r\n        <tbody>\r\n            {% for item in doc.items %}\r\n            <tr>\r\n                <td>{{ item.item_name }}</td>\r\n                <td style=\"text-align: center;\">{{ item.qty|int }}</td>\r\n                <td style=\"text-align: right;\">Rs {{ \"{:,.2f}\".format(item.amount or 0) }}</td>\r\n            </tr>\r\n            {% endfor %}\r\n        </tbody>\r\n    </table>\r\n\r\n    <div class=\"summary-section\">\r\n        <div class=\"terms\">\r\n            <b>Terms & Conditions:</b>\r\n            1. Fee must be paid by the 10th of each month.<br>\r\n            2. Late fine applies after due date.<br>\r\n            3. Paid amounts are non-refundable.\r\n        </div>\r\n\r\n        <div class=\"summary-box\">\r\n            <div class=\"summary-row\">\r\n                <span>Sub Total</span>\r\n                <span>Rs {{ \"{:,.2f}\".format(doc.total or 0) }}</span>\r\n            </div>\r\n\r\n            {% if doc.discount_amount %}\r\n            <div class=\"summary-row\" style=\"color:#c53030;\">\r\n                <span>Discount</span>\r\n                <span>-Rs {{ \"{:,.2f}\".format(doc.discount_amount) }}</span>\r\n            </div>\r\n            {% endif %}\r\n\r\n            <div class=\"total-line\">\r\n                <span>GRAND TOTAL</span>\r\n                <span>Rs {{ \"{:,.2f}\".format(doc.grand_total or 0) }}</span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n</div>\r\n\r\n{% if loop.first %}\r\n<div class=\"divider\"></div>\r\n{% endif %}\r\n\r\n{% endfor %}\r\n</div>",
